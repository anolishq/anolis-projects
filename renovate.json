{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>anolishq/renovate-config"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update component versions pinned in machine-profile.yaml",
      "managerFilePatterns": [
        "/projects/.+/machine-profile\\.yaml$/"
      ],
      "matchStrings": [
        "repo:\\s*(?<depName>[^\\s]+)\\s*\\n\\s*version:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Bump the canonical machine-profile schema pin (CI fetches it from the anolis release)",
      "managerFilePatterns": [
        "/^schema-source\\.json$/"
      ],
      "matchStrings": [
        "\"repo\":\\s*\"(?<depName>[^\"]+)\",\\s*\\n\\s*\"version\":\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    }
  ],
  "packageRules": [
    {
      "description": "Group all anolis component updates into a single PR",
      "matchManagers": ["custom.regex"],
      "groupName": "anolis components",
      "commitMessagePrefix": "deps:",
      "semanticCommitType": "deps"
    }
  ]
}
