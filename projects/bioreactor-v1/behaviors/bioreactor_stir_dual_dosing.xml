<?xml version="1.0"?>
<root BTCPP_format="4">
  <!--
    Bioreactor stir + dual dosing automation:
    - Maintain impeller command (dcmt0 motor2)
    - Keep sample pump off by default in automation (dcmt0 motor1=0)
    - Run two independent dosing schedules on dcmt1 (motor1=dose1, motor2=dose2)
    - Emit set_open_loop only on command change or keepalive

    All machine semantics live in config/BT assets; core runtime remains provider-agnostic.
  -->
  <BehaviorTree ID="BioreactorStirDualDosing">
    <ReactiveSequence name="stir_dual_dosing_control_loop">
      <!-- Runtime-tunable parameters -->
      <GetParameterBool param="impeller_enable" value="{impeller_enable}"/>
      <GetParameter param="impeller_pwm" value="{impeller_pwm}"/>

      <GetParameterBool param="dose1_enable" value="{dose1_enable}"/>
      <GetParameter param="dose1_pwm" value="{dose1_pwm}"/>
      <GetParameterInt64 param="dose1_startup_delay_s" value="{dose1_startup_delay_s}"/>
      <GetParameterInt64 param="dose1_interval_s" value="{dose1_interval_s}"/>
      <GetParameterInt64 param="dose1_pulse_s" value="{dose1_pulse_s}"/>
      <GetParameterInt64 param="dose1_max_pulses_per_hour" value="{dose1_max_pulses_per_hour}"/>

      <GetParameterBool param="dose2_enable" value="{dose2_enable}"/>
      <GetParameter param="dose2_pwm" value="{dose2_pwm}"/>
      <GetParameterInt64 param="dose2_startup_delay_s" value="{dose2_startup_delay_s}"/>
      <GetParameterInt64 param="dose2_interval_s" value="{dose2_interval_s}"/>
      <GetParameterInt64 param="dose2_pulse_s" value="{dose2_pulse_s}"/>
      <GetParameterInt64 param="dose2_max_pulses_per_hour" value="{dose2_max_pulses_per_hour}"/>

      <GetParameterInt64 param="command_keepalive_s" value="{command_keepalive_s}"/>
      <GetParameterInt64 param="command_min_spacing_ms" value="{command_min_spacing_ms}"/>

      <!-- Independent dosing schedulers -->
      <PeriodicPulseWindow enabled="{dose1_enable}" startup_delay_s="{dose1_startup_delay_s}" interval_s="{dose1_interval_s}" pulse_s="{dose1_pulse_s}" max_pulses_per_hour="{dose1_max_pulses_per_hour}" active="{dose1_active}" pulse_index="{dose1_pulse_index}" elapsed_ms="{dose1_elapsed_ms}"/>
      <PeriodicPulseWindow enabled="{dose2_enable}" startup_delay_s="{dose2_startup_delay_s}" interval_s="{dose2_interval_s}" pulse_s="{dose2_pulse_s}" max_pulses_per_hour="{dose2_max_pulses_per_hour}" active="{dose2_active}" pulse_index="{dose2_pulse_index}" elapsed_ms="{dose2_elapsed_ms}"/>

      <!-- dcmt0: sample channel held off, impeller controlled -->
      <Fallback name="compose_dcmt0_open_loop_args">
        <Sequence>
          <CheckBool value="{impeller_enable}" expected="true"/>
          <BuildArgsJson arg1_name="motor1_pwm" arg1_type="int64" arg1_num="0" arg2_name="motor2_pwm" arg2_type="int64" arg2_num="{impeller_pwm}" json="{dcmt0_open_loop_args}"/>
        </Sequence>
        <Sequence>
          <CheckBool value="{impeller_enable}" expected="false"/>
          <BuildArgsJson arg1_name="motor1_pwm" arg1_type="int64" arg1_num="0" arg2_name="motor2_pwm" arg2_type="int64" arg2_num="0" json="{dcmt0_open_loop_args}"/>
        </Sequence>
      </Fallback>

      <EmitOnChangeOrInterval key="{dcmt0_open_loop_args}" keepalive_s="{command_keepalive_s}" min_spacing_ms="{command_min_spacing_ms}" emit="{dcmt0_emit}" reason="{dcmt0_emit_reason}"/>

      <Fallback name="write_dcmt0_if_emit">
        <Sequence>
          <CheckBool value="{dcmt0_emit}" expected="true"/>
          <CallDevice device_handle="bread0/dcmt0" function_name="set_open_loop" args="{dcmt0_open_loop_args}" success="{dcmt0_write_ok}" error="{dcmt0_write_error}"/>
        </Sequence>
        <AlwaysSuccess/>
      </Fallback>

      <!-- dcmt1: dual independent dosing channels -->
      <Fallback name="compose_dcmt1_open_loop_args">
        <Sequence>
          <CheckBool value="{dose1_active}" expected="true"/>
          <CheckBool value="{dose2_active}" expected="true"/>
          <BuildArgsJson arg1_name="motor1_pwm" arg1_type="int64" arg1_num="{dose1_pwm}" arg2_name="motor2_pwm" arg2_type="int64" arg2_num="{dose2_pwm}" json="{dcmt1_open_loop_args}"/>
        </Sequence>

        <Sequence>
          <CheckBool value="{dose1_active}" expected="true"/>
          <CheckBool value="{dose2_active}" expected="false"/>
          <BuildArgsJson arg1_name="motor1_pwm" arg1_type="int64" arg1_num="{dose1_pwm}" arg2_name="motor2_pwm" arg2_type="int64" arg2_num="0" json="{dcmt1_open_loop_args}"/>
        </Sequence>

        <Sequence>
          <CheckBool value="{dose1_active}" expected="false"/>
          <CheckBool value="{dose2_active}" expected="true"/>
          <BuildArgsJson arg1_name="motor1_pwm" arg1_type="int64" arg1_num="0" arg2_name="motor2_pwm" arg2_type="int64" arg2_num="{dose2_pwm}" json="{dcmt1_open_loop_args}"/>
        </Sequence>

        <Sequence>
          <CheckBool value="{dose1_active}" expected="false"/>
          <CheckBool value="{dose2_active}" expected="false"/>
          <BuildArgsJson arg1_name="motor1_pwm" arg1_type="int64" arg1_num="0" arg2_name="motor2_pwm" arg2_type="int64" arg2_num="0" json="{dcmt1_open_loop_args}"/>
        </Sequence>
      </Fallback>

      <EmitOnChangeOrInterval key="{dcmt1_open_loop_args}" keepalive_s="{command_keepalive_s}" min_spacing_ms="{command_min_spacing_ms}" emit="{dcmt1_emit}" reason="{dcmt1_emit_reason}"/>

      <Fallback name="write_dcmt1_if_emit">
        <Sequence>
          <CheckBool value="{dcmt1_emit}" expected="true"/>
          <CallDevice device_handle="bread0/dcmt1" function_name="set_open_loop" args="{dcmt1_open_loop_args}" success="{dcmt1_write_ok}" error="{dcmt1_write_error}"/>
        </Sequence>
        <AlwaysSuccess/>
      </Fallback>
    </ReactiveSequence>
  </BehaviorTree>
</root>
